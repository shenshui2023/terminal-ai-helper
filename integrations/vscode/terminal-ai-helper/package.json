{
  "name": "terminal-ai-helper",
  "displayName": "终端 AI 助手",
  "description": "解释、诊断和补全终端命令；支持选中文本、剪贴板和本地面板。",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:terminalAiHelper.explainSelection",
    "onCommand:terminalAiHelper.fixSelection",
    "onCommand:terminalAiHelper.explainClipboard",
    "onCommand:terminalAiHelper.fixClipboard",
    "onCommand:terminalAiHelper.openPanelSelection",
    "onCommand:terminalAiHelper.openPanelClipboard",
    "onCommand:terminalAiHelper.openSettings"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "终端 AI 助手",
      "properties": {
        "terminalAiHelper.cliPath": {
          "type": "string",
          "default": "E:\\\\3.13-aliyun-codex\\\\5.2\\\\terminal-ai-helper\\\\bin\\\\taih.js",
          "description": "taih.js 的完整路径。"
        },
        "terminalAiHelper.defaultStyle": {
          "type": "string",
          "enum": [
            "brief",
            "standard",
            "examples"
          ],
          "default": "brief",
          "description": "VS Code 输出窗口默认使用的回答风格。"
        },
        "terminalAiHelper.usePanelByDefault": {
          "type": "boolean",
          "default": false,
          "description": "右键解释/诊断时是否默认打开项目自带面板，而不是 VS Code 输出窗口。"
        }
      }
    },
    "commands": [
      {
        "command": "terminalAiHelper.explainSelection",
        "title": "终端 AI 助手：解释选中文本"
      },
      {
        "command": "terminalAiHelper.fixSelection",
        "title": "终端 AI 助手：诊断选中文本"
      },
      {
        "command": "terminalAiHelper.explainClipboard",
        "title": "终端 AI 助手：解释剪贴板"
      },
      {
        "command": "terminalAiHelper.fixClipboard",
        "title": "终端 AI 助手：诊断剪贴板"
      },
      {
        "command": "terminalAiHelper.openPanelSelection",
        "title": "终端 AI 助手：用侧栏面板解释选中文本"
      },
      {
        "command": "terminalAiHelper.openPanelClipboard",
        "title": "终端 AI 助手：用侧栏面板解释剪贴板"
      },
      {
        "command": "terminalAiHelper.openSettings",
        "title": "终端 AI 助手：打开配置"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "terminalAiHelper.explainSelection",
          "group": "navigation@90",
          "when": "editorHasSelection"
        },
        {
          "command": "terminalAiHelper.fixSelection",
          "group": "navigation@91",
          "when": "editorHasSelection"
        },
        {
          "command": "terminalAiHelper.openPanelSelection",
          "group": "navigation@92",
          "when": "editorHasSelection"
        }
      ]
    }
  }
}
